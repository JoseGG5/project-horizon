# postgres
POSTGRES_DB=  # Name of the PostgreSQL database the demo stack should create and use.
POSTGRES_USER=  # Username for the PostgreSQL container and for API connections.
POSTGRES_PASSWORD=  # Password for the PostgreSQL user used by the local stack.
POSTGRES_PORT=  # Host port that exposes PostgreSQL outside Docker, usually 5432.
DATABASE_URL=  # SQLAlchemy connection string the API uses to reach PostgreSQL inside Docker.

# api
API_PORT=  # Host port that exposes the FastAPI service outside Docker.
RAY_SERVE_URL=  # Internal Ray Serve base URL the API uses to request embeddings.
EMBEDDING_DIMENSION=  # Embedding vector size expected by pgvector and the application schema.

# monitoring
PROMETHEUS_PORT=  # Host port that exposes the Prometheus UI and API outside Docker.
GRAFANA_PORT=  # Host port that exposes the Grafana UI outside Docker.
METRICS_EXPORT_PORT=  # Host port that exposes Ray's Prometheus-format metrics endpoint.

# ray serve
RAY_SERVE_PORT=  # Host port that exposes the Ray Serve HTTP API outside Docker.
MODEL_PATH=  # Path inside the Ray container where the sentence-transformer checkpoint is mounted.
NORMALIZE_EMBEDDINGS=  # Whether Ray should normalize embeddings before returning them.
MAX_BATCH_SIZE=  # Max number of texts Ray should process together in one embedding batch.
NUM_REPLICAS=  # Number of Ray Serve replicas to run for the embedding deployment.
RAY_NUM_CPUS=  # CPUs reserved for each Ray Serve replica.
RAY_NUM_GPUS=  # GPUs reserved for each Ray Serve replica.
RAY_SHM_SIZE=  # Shared memory size for the Ray container to avoid runtime memory issues.
SERVE_HOST=  # Bind host for the Ray Serve HTTP server inside the container.
SERVE_PORT=  # Internal container port where Ray Serve listens for HTTP requests.

# ray dashboard
DASHBOARD_HOST=  # Bind host for the Ray Dashboard inside the container.
DASHBOARD_PORT=  # Host and container port used to expose the Ray Dashboard UI.
RAY_GRAFANA_HOST=  # Internal Grafana URL Ray uses from inside Docker for dashboard integration.
RAY_PROMETHEUS_HOST=  # Internal Prometheus URL Ray uses from inside Docker for metrics integration.
RAY_PROMETHEUS_NAME=  # Grafana datasource name that Ray expects when building embedded panels.
RAY_GRAFANA_ORG_ID=  # Grafana organization id Ray should use when generating dashboard links.
RAY_GRAFANA_IFRAME_HOST=  # Browser-visible Grafana URL used by Ray when embedding Grafana iframes.

# gpu / nvidia
NVIDIA_GPU_COUNT=  # Number of NVIDIA GPUs Docker should reserve for the Ray container.
NVIDIA_VISIBLE_DEVICES=  # Which NVIDIA devices should be visible inside the Ray container.
NVIDIA_DRIVER_CAPABILITIES=  # NVIDIA runtime capabilities needed by the Ray workload.
